    </div> <!-- end .container -->

    <!-- QR Modal Popup -->
    <div class="modal-overlay" id="qrModal">
        <div class="modal-content">
            <button class="modal-close" onclick="closeQrModal()">&times;</button>
            <h3 id="modalTitle" style="margin-bottom: 0.5rem;">QR Code</h3>
            <p id="modalShortUrl" style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem; word-break: break-all;"></p>
            
            <div style="background: #fff; padding: 1rem; border-radius: var(--radius-md); display: inline-block; margin-bottom: 1.5rem;">
                <img id="modalQrImage" src="" alt="QR Code" style="width: 200px; height: 200px; display: block;">
            </div>

            <div>
                <a id="downloadQrBtn" href="" download="qr-code.png" class="btn btn-primary">
                    <i class="fa-solid fa-download"></i> Download PNG
                </a>
            </div>
        </div>
    </div>

    <footer>
        <p>&copy; <%= new Date().getFullYear() %> <strong>LinkPulse</strong>. Engineered for lightning performance and clean analytics.</p>
    </footer>

    <!-- Client Script -->
    <script src="/js/main.js"></script>
</body>
</html>
