<%- include('partials/header') %>

<div style="margin-bottom: 2rem;">
    <h1 style="font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem;">
        Welcome back, <span style="background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"><%= user.name %></span>!
    </h1>
    <p style="color: var(--text-muted);">Manage your shortened links and monitor performance in real-time.</p>
</div>

<% if (locals.error) { %>
    <div class="alert alert-danger">
        <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
    </div>
<% } %>

<% if (locals.success) { %>
    <div class="alert alert-success">
        <i class="fa-solid fa-circle-check"></i> <%= success %>
    </div>
<% } %>

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon"><i class="fa-solid fa-link"></i></div>
        <div>
            <div class="stat-value"><%= stats.totalLinks %></div>
            <div class="stat-label">Total Short Links</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="color: var(--secondary); background: rgba(168, 85, 247, 0.15);"><i class="fa-solid fa-mouse-pointer"></i></div>
        <div>
            <div class="stat-value"><%= stats.totalClicks %></div>
            <div class="stat-label">Total Link Clicks</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="color: var(--accent-cyan); background: rgba(6, 182, 212, 0.15);"><i class="fa-solid fa-circle-check"></i></div>
        <div>
            <div class="stat-value"><%= stats.activeLinks %></div>
            <div class="stat-label">Active Links</div>
        </div>
    </div>
</div>

<!-- Quick Link Generator Modal / Inline Form -->
<div class="glass-card" style="margin-bottom: 2.5rem; padding: 1.5rem;">
    <h3 style="font-size: 1.1rem; margin-bottom: 1rem; font-weight: 700;">
        <i class="fa-solid fa-plus-circle" style="color: var(--primary);"></i> Create New Short Link
    </h3>
    <form action="/url" method="POST" class="shortener-form">
        <div class="form-row">
            <div class="form-group" style="flex: 2;">
                <input type="text" name="url" class="form-control" placeholder="Destination URL (e.g. https://github.com)" required>
            </div>
            <div class="form-group">
                <input type="text" name="customAlias" class="form-control" placeholder="Custom Alias (optional)">
            </div>
            <div class="form-group">
                <input type="text" name="title" class="form-control" placeholder="Title (optional)">
            </div>
            <div class="form-group" style="max-width: 140px;">
                <button type="submit" class="btn btn-primary" style="width: 100%;">
                    <i class="fa-solid fa-bolt"></i> Shorten
                </button>
            </div>
        </div>
    </form>
</div>

<!-- Links Table -->
<div class="table-header">
    <h2 style="font-size: 1.5rem; font-weight: 700;">Your Short Links</h2>
    <input type="text" id="tableSearch" class="form-control search-input" placeholder="Search links...">
</div>

<div class="table-responsive">
    <table class="custom-table" id="urlsTable">
        <thead>
            <tr>
                <th>Title / Redirect URL</th>
                <th>Short Link</th>
                <th>Clicks</th>
                <th>Expires</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (urls && urls.length > 0) { %>
                <% urls.forEach(url => { %>
                    <tr>
                        <td>
                            <div style="font-weight: 600; color: var(--text-main); margin-bottom: 0.2rem;"><%= url.title || 'Untitled Link' %></div>
                            <div style="font-size: 0.82rem; color: var(--text-muted); max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                <%= url.redirectUrl %>
                            </div>
                        </td>
                        <td>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <a href="<%= url.fullShortUrl %>" target="_blank" style="font-weight: 600;"><%= url.fullShortUrl %></a>
                                <button type="button" class="btn btn-secondary btn-sm" onclick="copyToClipboard('<%= url.fullShortUrl %>', 'Copied short URL!')" title="Copy Link">
                                    <i class="fa-solid fa-copy"></i>
                                </button>
                            </div>
                        </td>
                        <td>
                            <span class="badge badge-success"><%= url.visitHistory.length %> Clicks</span>
                        </td>
                        <td>
                            <% if (url.expiresAt) { %>
                                <span class="badge badge-secondary" title="<%= new Date(url.expiresAt).toLocaleString() %>">
                                    <%= new Date(url.expiresAt).toLocaleDateString() %>
                                </span>
                            <% } else { %>
                                <span class="badge badge-secondary">Never</span>
                            <% } %>
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.4rem;">
                                <a href="/analytics/<%= url.shortId %>" class="btn btn-secondary btn-sm" title="View Analytics">
                                    <i class="fa-solid fa-chart-simple"></i>
                                </a>
                                <button type="button" class="btn btn-secondary btn-sm" onclick="openQrModal('<%= url.qrCode %>', '<%= url.title %>', '<%= url.fullShortUrl %>')" title="View QR Code">
                                    <i class="fa-solid fa-qrcode"></i>
                                </button>
                                <form action="/url/<%= url._id %>?_method=DELETE" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this short link?');">
                                    <button type="submit" class="btn btn-danger btn-sm" title="Delete Link">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 3rem;">
                        <i class="fa-regular fa-folder-open" style="font-size: 2.5rem; margin-bottom: 0.75rem; display: block;"></i>
                        No short links created yet. Create your first link above!
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>
