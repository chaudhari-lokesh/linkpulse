<%- include('partials/header') %>

<div class="hero">
    <div class="hero-badge">
        <i class="fa-solid fa-wand-magic-sparkles"></i> Powerful & Fast Link Management
    </div>
    <h1 class="hero-title">
        Shorten Links, Expand Your <span>Digital Reach</span>
    </h1>
    <p class="hero-subtitle">
        Transform long URLs into memorable, brandable short links. Generate instant QR codes and track detailed click analytics effortlessly.
    </p>
</div>

<% if (locals.error) { %>
    <div class="alert alert-danger">
        <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
    </div>
<% } %>

<% if (locals.success) { %>
    <div class="alert alert-success">
        <i class="fa-solid fa-circle-check"></i> <%= success %>
    </div>
<% } %>

<div class="shortener-box">
    <div class="glass-card">
        <form action="/url" method="POST" class="shortener-form">
            <div class="form-group">
                <label class="form-label" for="urlInput">Destination URL</label>
                <input type="text" id="urlInput" name="url" class="form-control" placeholder="https://example.com/very-long-url-path" required>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="customAlias">Custom Alias (Optional)</label>
                    <input type="text" id="customAlias" name="customAlias" class="form-control" placeholder="my-custom-name">
                </div>

                <div class="form-group">
                    <label class="form-label" for="titleInput">Link Title (Optional)</label>
                    <input type="text" id="titleInput" name="title" class="form-control" placeholder="Campaign Landing Page">
                </div>

                <div class="form-group">
                    <label class="form-label" for="expiration">Expiration (Optional)</label>
                    <select id="expiration" name="expiration" class="form-control">
                        <option value="">Never Expire</option>
                        <option value="24h">24 Hours</option>
                        <option value="7d">7 Days</option>
                        <option value="30d">30 Days</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="margin-top: 0.5rem; width: 100%; padding: 0.9rem;">
                <i class="fa-solid fa-link"></i> Shorten URL Now
            </button>
        </form>

        <% if (locals.id && locals.shortUrl) { %>
            <div class="result-card">
                <div style="display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap;">
                    <% if (locals.qrCode) { %>
                        <img src="<%= qrCode %>" alt="QR Code" class="qr-thumb" onclick="openQrModal('<%= qrCode %>', 'Short URL QR Code', '<%= shortUrl %>')" style="cursor: pointer;">
                    <% } %>
                    <div class="result-info">
                        <span style="font-size: 0.8rem; text-transform: uppercase; color: var(--accent-cyan); font-weight: 700;">Short Link Ready!</span>
                        <div class="result-url"><%= shortUrl %></div>
                        <span style="font-size: 0.85rem; color: var(--text-muted); word-break: break-all;">Original: <%= redirectUrl %></span>
                    </div>
                </div>
                <div class="result-actions">
                    <button type="button" class="btn btn-secondary btn-sm" onclick="copyToClipboard('<%= shortUrl %>', 'Short link copied!')">
                        <i class="fa-solid fa-copy"></i> Copy
                    </button>
                    <% if (locals.qrCode) { %>
                        <button type="button" class="btn btn-secondary btn-sm" onclick="openQrModal('<%= qrCode %>', 'Short URL QR Code', '<%= shortUrl %>')">
                            <i class="fa-solid fa-qrcode"></i> QR Code
                        </button>
                    <% } %>
                    <a href="/analytics/<%= id %>" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-chart-line"></i> Analytics
                    </a>
                </div>
            </div>
        <% } %>
    </div>
</div>

<!-- Features Section -->
<div class="features-grid">
    <div class="glass-card feature-card">
        <div class="feature-icon" style="color: #6366f1;"><i class="fa-solid fa-shield-halved"></i></div>
        <h3 class="feature-title">Custom Branding</h3>
        <p class="feature-desc">Replace random strings with custom aliases that reinforce your brand and boost click-through rates.</p>
    </div>
    <div class="glass-card feature-card">
        <div class="feature-icon" style="color: #a855f7;"><i class="fa-solid fa-chart-pie"></i></div>
        <h3 class="feature-title">Real-Time Analytics</h3>
        <p class="feature-desc">Track total clicks, referrers, user agents, and IP addresses with visually interactive graphs.</p>
    </div>
    <div class="glass-card feature-card">
        <div class="feature-icon" style="color: #06b6d4;"><i class="fa-solid fa-qrcode"></i></div>
        <h3 class="feature-title">Instant QR Codes</h3>
        <p class="feature-desc">Every shortened link comes with an auto-generated QR code ready to download for print and media campaigns.</p>
    </div>
</div>

<%- include('partials/footer') %>